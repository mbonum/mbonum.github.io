<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Start Node -->
    <mxCell id="2" value="Start" style="ellipse;whiteSpace=wrap;fillColor=#acf9fd;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="100" width="80" height="40" as="geometry"/>
    </mxCell>

    <!-- Enter Username -->
    <mxCell id="3" value="Enter Username" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="180" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Enter Password -->
    <mxCell id="4" value="Enter Password" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="280" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Validate Credentials (Decision) -->
    <mxCell id="5" value="Validate Credentials" style="rhombus;whiteSpace=wrap;fillColor=#fce8b5;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="380" width="140" height="80" as="geometry"/>
    </mxCell>

    <!-- Success Node -->
    <mxCell id="6" value="Login Successful" style="ellipse;whiteSpace=wrap;fillColor=#acf9fd;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="480" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Error Node -->
    <mxCell id="7" value="Login Failed" style="ellipse;whiteSpace=wrap;fillColor=#f9c5c5;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="350" y="480" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Show Error Message -->
    <mxCell id="8" value="Show Error Message" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="350" y="380" width="140" height="60" as="geometry"/>
    </mxCell>

    <!-- Redirect to Home -->
    <mxCell id="9" value="Redirect to Home" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="560" width="140" height="60" as="geometry"/>
    </mxCell>

    <!-- Edges -->
    <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="2" target="3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="3" target="4" parent="1"
>
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="4" target="5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="5" target="6" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e5" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="5" target="7" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="7" target="8" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="6" target="9" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e8" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="8" target="4" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="420" y="410"/>
          <mxPoint x="420" y="310"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
